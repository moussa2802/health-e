rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'admin';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Contrôle d'accès vie intime
      match /acces/{document} {
        allow read, write: if isOwner(userId);
      }

      // Journal intime
      match /journal/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // Chat Dr Lô
      match /chat_dr_lo/{conversationId} {
        allow read, write: if isOwner(userId);
      }

      // Prompts journal intelligents
      match /journal_prompts/{promptId} {
        allow read, write: if isOwner(userId);
      }

      // Cache des conseils Dr Lô par évaluation
      match /conseils_cache/{scaleId} {
        allow read, write: if isOwner(userId);
      }

      // État onboarding (welcome + tooltips vus)
      match /onboarding/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── PROFESSIONALS ────────────────────────────────────────────────────────
    match /professionals/{professionalId} {
      allow read;
      allow write: if request.auth != null &&
        (request.auth.uid == professionalId || isAdmin());
    }

    // ─── PROFESSIONALS PUBLIC (homepage) ──────────────────────────────────────
    match /professionals_public/{professionalId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── PATIENTS ─────────────────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read, write: if isOwner(patientId);
    }

    // ─── MEDICAL RECORDS ──────────────────────────────────────────────────────
    match /patients/{patientId}/medicalRecords/{recordId} {
      allow read: if request.auth != null &&
        (isOwner(patientId) || request.auth.uid == resource.data.professionalId);
      allow create: if request.auth != null &&
        request.resource.data.professionalId == request.auth.uid;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.professionalId;
    }

    // collectionGroup query (used by professionals to list records)
    match /{path=**}/medicalRecords/{recordId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'professional';
    }

    // ─── BOOKINGS ─────────────────────────────────────────────────────────────
    // IPN updates via Admin SDK (bypasses rules). Client-side: owner only.
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
        (resource.data.patientId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);

      allow create: if request.auth != null &&
        request.resource.data.patientId == request.auth.uid;

      allow update: if request.auth != null &&
        (resource.data.patientId == request.auth.uid ||
         resource.data.professionalId == request.auth.uid);

      allow delete: if false;
    }

    // ─── TEMP REDIRECTS (created by IPN via Admin SDK) ────────────────────────
    match /temp_redirects/{tempId} {
      allow read: if request.auth != null;
    }

    // ─── ROOM LINKS (created by Cloud Functions via Admin SDK) ────────────────
    match /roomLinks/{token} {
      allow read: if request.auth != null;
    }

    // ─── CONVERSATIONS ─────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // ─── CONTENT (FAQ, Terms, etc.) ───────────────────────────────────────────
    match /content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── CALENDAR EVENTS ──────────────────────────────────────────────────────
    match /calendar_events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.professionalId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.professionalId == request.auth.uid;
    }

    // ─── NOTIFICATIONS ────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // ─── SUPPORT TICKETS ──────────────────────────────────────────────────────
    match /supportTickets/{ticketId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /supportMessages/{messageId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/supportTickets/$(resource.data.ticketId)) &&
        get(/databases/$(database)/documents/supportTickets/$(resource.data.ticketId)).data.userId == request.auth.uid;

      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/supportTickets/$(resource.data.ticketId)) &&
        (get(/databases/$(database)/documents/supportTickets/$(resource.data.ticketId)).data.userId == request.auth.uid ||
         isAdmin());
    }

    // ─── REVENUE & WITHDRAWALS ────────────────────────────────────────────────
    // Written by Netlify functions (Admin SDK). Client: read-only for owner.
    match /revenue_transactions/{transactionId} {
      allow read: if request.auth != null &&
        resource.data.professionalId == request.auth.uid;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if request.auth != null &&
        resource.data.professionalId == request.auth.uid;
    }

    match /withdrawalRequests/{requestId} {
      allow create: if request.auth != null &&
        request.resource.data.professionalId == request.auth.uid &&
        request.resource.data.status == "pending";

      allow read: if request.auth != null &&
        resource.data.professionalId == request.auth.uid;

      allow update: if request.auth != null &&
        resource.data.professionalId == request.auth.uid &&
        request.resource.data.amount == resource.data.amount &&
        request.resource.data.method == resource.data.method &&
        request.resource.data.professionalId == resource.data.professionalId;
    }

    // ─── PROFESSIONAL PATIENTS ────────────────────────────────────────────────
    match /professional_patients/{document} {
      allow read: if request.auth != null &&
        resource.data.professionalId == request.auth.uid;

      allow write: if request.auth != null &&
        request.auth.uid == resource.data.professionalId;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.professionalId &&
        request.resource.data.patientId is string &&
        request.resource.data.professionalId is string;
    }

    // ─── MAIL (Trigger Email extension — Cloud Functions write via Admin SDK) ──
    match /mail/{mailId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── GROUP THERAPY ────────────────────────────────────────────────────────
    match /group_therapy_sessions/{sessionId} {
      allow read: if true;

      allow create: if isAdmin();

      allow update: if request.auth != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)) &&
         (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.primaryHostId == request.auth.uid ||
          (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds != null &&
           request.auth.uid in get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds)) &&
         request.resource.data.diff(resource.data).changedKeys().hasOnly(['meetingStatus', 'openedBy', 'openedAt', 'meetingLink', 'updatedAt'])) ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['registrationsCount', 'updatedAt'])
      );

      allow delete: if isAdmin();

      match /private/meeting {
        allow read: if request.auth != null && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)) &&
           (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.primaryHostId == request.auth.uid ||
            (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds != null &&
             request.auth.uid in get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds))) ||
          exists(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)/registrations/$(request.auth.uid))
        );

        allow create, update: if request.auth != null && (
          isAdmin() ||
          (exists(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)) &&
           (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.primaryHostId == request.auth.uid ||
            (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds != null &&
             request.auth.uid in get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds)))
        ) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['meetingStatus', 'meetingLink', 'openedBy', 'openedAt', 'updatedAt']);

        allow delete: if isAdmin();
      }
    }

    match /group_therapy_sessions/{sessionId}/registrations/{userId} {
      allow read: if request.auth != null && (
        isOwner(userId) ||
        isAdmin() ||
        (exists(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)) &&
         (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.primaryHostId == request.auth.uid ||
          (get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds != null &&
           request.auth.uid in get(/databases/$(database)/documents/group_therapy_sessions/$(sessionId)).data.secondaryHostIds)))
      );

      allow create: if request.auth != null &&
        userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null &&
        (userId == request.auth.uid || isAdmin());
    }

    // ─── ADMIN CATCHALL ───────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Health-e 2.0 : Évaluations ──────────────────────────────────────
    match /assessmentSessions/{sessionId} {
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Lecture autorisée pour tout utilisateur connecté — nécessaire pour la fonctionnalité de compatibilité
      allow read: if request.auth != null;

      // Sous-collection historique des résultats
      match /scaleResultHistory/{entryId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /compatibilityRequests/{requestId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.initiatorUserId == request.auth.uid);
      allow delete: if false;
    }

    match /compatibilityHistory/{entryId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
