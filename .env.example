# ─── Firebase ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# ─── PayTech (Netlify functions) ─────────────────────────────────────────────
PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_ENV=prod
PAYTECH_SUCCESS_URL=https://health-e.sn/appointment-success
PAYTECH_CANCEL_URL=https://health-e.sn/book
PAYTECH_IPN_URL=https://health-e.sn/.netlify/functions/paytech-ipn

# ─── Firebase Admin (Netlify functions) ──────────────────────────────────────
# JSON stringifié du fichier de compte de service Firebase
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_DATABASE_URL=https://health-e-af2bf-default-rtdb.firebaseio.com

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Créer un projet sur https://sentry.io et copier le DSN ici
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0
# Pour uploader les source maps lors du build de production :
SENTRY_AUTH_TOKEN=
SENTRY_ORG=health-e
SENTRY_PROJECT=health-e-frontend

# ─── Jitsi / Vidéo (OVH) ─────────────────────────────────────────────────────
# Domaine de votre serveur Jitsi sur OVH
VITE_JITSI_DOMAIN=meet.health-e.sn
# Serveur TURN coturn sur OVH (améliore la fiabilité mobile en Afrique)
# Pour installer coturn : apt install coturn
# Puis configurer /etc/turnserver.conf avec votre IP OVH
VITE_TURN_SERVER=turn.health-e.sn
VITE_TURN_USERNAME=health-e
VITE_TURN_CREDENTIAL=

# ─── WhatsApp (Firebase Functions) ───────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_HMAC_SECRET=
